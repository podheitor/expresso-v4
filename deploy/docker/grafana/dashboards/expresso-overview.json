{
  "title": "Expresso — Overview",
  "uid": "expresso-overview",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Services UP",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "sum(up{job=~\"expresso-.+\"})", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } } }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Up status per service",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 0 },
      "targets": [{ "expr": "up{job=~\"expresso-.+\"}", "legendFormat": "{{service}}", "refId": "A" }]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "HTTP requests total — rate(5m)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [{ "expr": "sum by (service) (rate(http_requests_total[5m]))", "legendFormat": "{{service}}", "refId": "A" }]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Process CPU seconds",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [{ "expr": "rate(process_cpu_seconds_total{job=~\"expresso-.+\"}[5m])", "legendFormat": "{{service}}", "refId": "A" }]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Process memory RSS",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [{ "expr": "process_resident_memory_bytes{job=~\"expresso-.+\"}", "legendFormat": "{{service}}", "refId": "A" }]
    }
  ]
}
