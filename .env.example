# Database
DATABASE_URL=postgres://expresso:secret@localhost:5432/expresso
REDIS_URL=redis://localhost:6379

# Object storage (MinIO)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=expresso
S3_SECRET_KEY=secret
S3_BUCKET=expresso

# Auth (Keycloak)
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=expresso
KEYCLOAK_CLIENT_ID=expresso-backend
KEYCLOAK_CLIENT_SECRET=change-me

# gov.br OIDC
GOVBR_ISSUER=https://sso.acesso.gov.br
GOVBR_CLIENT_ID=change-me
GOVBR_CLIENT_SECRET=change-me

# NATS
NATS_URL=nats://localhost:4222

# Service ports
MAIL_HTTP_PORT=8001
CALENDAR_PORT=8002
CONTACTS_PORT=8003
DRIVE_PORT=8004
WOPI_PORT=8005
AUTH_PORT=8080
ADMIN_PORT=8008

# Rust log level
RUST_LOG=info,expresso=debug
