# Stage 1: Builder — compile expresso-web
FROM rust:latest AS builder

WORKDIR /workspace

RUN apt-get update && apt-get install -y \
    pkg-config libssl-dev \
    && rm -rf /var/lib/apt/lists/*

COPY Cargo.toml Cargo.lock ./
COPY services/ services/
COPY libs/ libs/
COPY migrations/ migrations/

RUN cargo fetch
RUN cargo build --release --package expresso-web

# Stage 2: Runtime
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN groupadd -r expresso && useradd -r -g expresso expresso

WORKDIR /app

COPY --from=builder /workspace/target/release/expresso-web /app/expresso-web
COPY services/expresso-web/static   /app/static
COPY services/expresso-web/templates /app/templates

ENV WEB__STATIC_DIR=/app/static

USER expresso

EXPOSE 8080

ENTRYPOINT ["/app/expresso-web"]
