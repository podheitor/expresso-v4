{
  "title": "Expresso \u2014 Overview",
  "uid": "expresso-overview",
  "schemaVersion": 39,
  "version": 2,
  "tags": [
    "expresso"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(http_requests_total, service)",
        "includeAll": true,
        "multi": true,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP req/s por servi\u00e7o",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (service) (rate(http_requests_total{service=~\"$service\"}[1m]))",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP 4xx/5xx por servi\u00e7o",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (service,status) (rate(http_requests_total{service=~\"$service\",status=~\"4..|5..\"}[1m]))",
          "legendFormat": "{{service}} {{status}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "429 Rate-limited (\u00faltimo 5m)",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(http_requests_total{status=\"429\"}[5m]))",
          "legendFormat": "429 hits"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Status mix (\u00faltimos 15m)",
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 8,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (status) (rate(http_requests_total[1m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "JetStream \u2014 mensagens (EXPRESSO_CALENDAR)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "nats_stream_messages{stream=\"EXPRESSO_CALENDAR\"}",
          "legendFormat": "messages"
        },
        {
          "expr": "nats_stream_bytes{stream=\"EXPRESSO_CALENDAR\"}",
          "legendFormat": "bytes"
        }
      ],
      "description": "Requer prometheus-nats-exporter apontando para http://expresso-nats:8222."
    },
    {
      "id": 6,
      "type": "stat",
      "title": "/readyz \u2014 servi\u00e7os OK",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(up{job=~\"expresso-.*\"})",
          "legendFormat": "up"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "NATS publish rate \u2014 produtores (calendar+contacts)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (kind,result) (rate(calendar_nats_publish_total[5m]))",
          "legendFormat": "calendar {{kind}}/{{result}}"
        },
        {
          "expr": "sum by (kind,result) (rate(contacts_nats_publish_total[5m]))",
          "legendFormat": "contacts {{kind}}/{{result}}"
        }
      ],
      "description": "Taxa de publica\u00e7\u00e3o JetStream por produtor (sprints #32). result \u2208 ok/err/serialize_err."
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "event-audit \u2014 consumo por stream",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (stream) (rate(event_audit_events_total[5m]))",
          "legendFormat": "{{stream}}"
        }
      ],
      "description": "Taxa de eventos processados pelo expresso-event-audit (sprint #31)."
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Lag produtor \u2192 consumidor (ok - audit)",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(calendar_nats_publish_total{result=\"ok\"}[5m])) - sum(rate(event_audit_events_total{stream=\"EXPRESSO_CALENDAR\"}[5m]))",
          "legendFormat": "calendar lag"
        },
        {
          "expr": "sum(rate(contacts_nats_publish_total{result=\"ok\"}[5m])) - sum(rate(event_audit_events_total{stream=\"EXPRESSO_CONTACTS\"}[5m]))",
          "legendFormat": "contacts lag"
        }
      ],
      "description": "Diferen\u00e7a rate(publish ok) \u2212 rate(audit consumed). Pr\u00f3ximo de 0 = pipeline saud\u00e1vel."
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Publish errors (5m)",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 40
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(calendar_nats_publish_total{result!=\"ok\"}[5m])) + sum(increase(contacts_nats_publish_total{result!=\"ok\"}[5m]))",
          "legendFormat": "errors"
        }
      ],
      "description": "Total de falhas de publish (err+serialize_err) nos \u00faltimos 5m."
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "JetStream \u2014 mensagens (EXPRESSO_CONTACTS)",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 40
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "nats_stream_messages{stream=\"EXPRESSO_CONTACTS\"}",
          "legendFormat": "messages"
        },
        {
          "expr": "nats_stream_bytes{stream=\"EXPRESSO_CONTACTS\"}",
          "legendFormat": "bytes"
        }
      ],
      "description": "Espelha painel do EXPRESSO_CALENDAR para o stream de contatos."
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "iMIP dispatch rate (by method/result)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 46,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(imip_dispatch_total[5m])) by (method,result)",
          "legendFormat": "{{method}} {{result}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "last",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Calendar iMIP publish rate (producer)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 46,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(calendar_imip_publish_total[5m])) by (method,result)",
          "legendFormat": "{{method}} {{result}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "last",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 100,
      "title": "iMIP success ratio (5m)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 54,
        "w": 8,
        "h": 6
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.9
              },
              {
                "color": "green",
                "value": 0.99
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(imip_dispatch_total{result=\"ok\"}[5m])) / clamp_min(sum(rate(imip_dispatch_total{result=~\"ok|send_err|parse_err|err\"}[5m])), 0.0001)",
          "legendFormat": "success",
          "refId": "A"
        }
      ]
    },
    {
      "id": 101,
      "title": "iMIP delivered (1h)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 8,
        "y": 54,
        "w": 8,
        "h": 6
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(imip_dispatch_total{result=\"ok\"}[1h]))",
          "legendFormat": "ok",
          "refId": "A"
        }
      ]
    },
    {
      "id": 102,
      "title": "iMIP errors (1h)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 16,
        "y": 54,
        "w": 8,
        "h": 6
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(imip_dispatch_total{result=\"send_err\"}[1h]))",
          "legendFormat": "send_err",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(imip_dispatch_total{result=\"parse_err\"}[1h]))",
          "legendFormat": "parse_err",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(imip_dispatch_total{result=\"err\"}[1h]))",
          "legendFormat": "err",
          "refId": "C"
        }
      ]
    },
    {
      "id": 200,
      "title": "Auth validations per tenant (5m rate)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 60,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "last",
            "sum"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (realm, result) (rate(auth_validation_total[5m]))",
          "legendFormat": "{{realm}} / {{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 201,
      "title": "Auth realm cache size",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 60,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "max(auth_realm_cache_size)",
          "legendFormat": "realms",
          "refId": "A"
        }
      ]
    },
    {
      "id": 202,
      "title": "Auth errors per tenant (1h)",
      "type": "bargauge",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 64,
        "w": 12,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (realm, result) (increase(auth_validation_total{result!=\"ok\"}[1h]))",
          "legendFormat": "{{realm}} / {{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 300,
      "title": "Mail auth checks (5m rate)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 72,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "last",
            "sum"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (check, result) (rate(mail_auth_checks_total[5m]))",
          "legendFormat": "{{check}} / {{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 301,
      "title": "Mail auth actions (5m rate)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 72,
        "w": 6,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (action) (rate(mail_auth_actions_total[5m]))",
          "legendFormat": "{{action}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 302,
      "title": "DMARC reject ratio (1h)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 18,
        "y": 72,
        "w": 6,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.02 },
              { "color": "red",    "value": 0.1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(mail_auth_actions_total{action=\"reject\"}[1h])) / clamp_min(sum(increase(mail_auth_actions_total[1h])), 1)",
          "legendFormat": "reject ratio",
          "refId": "A"
        }
      ]
    }
  ]
}